# ===== Backend =====
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/myntra_clone
JWT_SECRET=replace_with_strong_secret
CLIENT_URL=http://localhost:5173

# AI: use 'stub' for offline deterministic behavior
AI_PROVIDER=stub
OPENROUTER_API_KEY=
OPENAI_API_KEY=
AI_MODEL=openrouter/auto

# Optional Cloudinary (if you want hosted images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== Frontend (create /frontend/.env) =====
# VITE_API_BASE=http://localhost:5000
